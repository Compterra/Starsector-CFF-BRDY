    "particleCount": 10,
    "particleDuration": 0.1,
    "particleSizeMin": 16,
    "particleSizeRange": 4,
    "spread": 6
  },
	"projectileSpecId":"pcc_shot",  # projectile that will be fired
  "fireSoundTwo": "brdy_lpcc_fire",
}